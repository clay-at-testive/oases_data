leads = read.csv('~/Desktop/leads.csv') %>%
filter(Lead...Archive.status == 'Not archived') %>%
rename(Opportunity.Title = Lead...Title, Source = Lead...Source.channel,
Create.Date = Lead...Lead.created, Owner = Lead...Owner,
Value = Lead...Value, Close.Date = Lead...Expected.close.date) %>%
mutate(Pipeline = '', Type = 'Lead', Client.Type = 'New', Stage = '', Age = 0,
Contact.Attempts = 0,
Create.Date = as.Date(Create.Date, format = '%Y-%m-%d')) %>%
select(Opportunity.Title, Type, Pipeline, Source, Client.Type, Age, Owner,
Contact.Attempts, Value, Stage, Close.Date, Create.Date)
deals = read.csv('~/Desktop/deals.csv') %>%
filter(Deal...Status == 'Open' & !grepl('ACTIVE', Deal...Title) &
!grepl('B2B', Deal...Pipeline) & !grepl('SPS', Deal...Pipeline)) %>%
rename(Opportunity.Title = Deal...Title, Pipeline = Deal...Pipeline,
Source = Deal...Source.channel, Create.Date = Deal...Deal.created,
Owner = Deal...Owner, Value = Deal...Value,
Close.Date = Deal...Expected.close.date,
Contact.Attempts = Deal...Done.activities, Stage = Deal...Stage) %>%
mutate(Type = 'Deal', Client.Type = '', Age = 0,
Create.Date = as.Date(Create.Date, format = '%Y-%m-%d')) %>%
select(Opportunity.Title, Owner, Type, Pipeline, Source, Client.Type, Age,
Contact.Attempts, Value, Stage, Close.Date, Create.Date) %>%
mutate(Client.Type = ifelse((Pipeline == 'Post-sale' |
grepl('Existing', Stage)), 'Existing', 'New'))
weekly_forecast = deals %>%
filter(Stage == 'Weekly Forecast') %>%
mutate(Create.Date = as.Date(Create.Date, format = '%Y-%m-%d')) %>%
mutate(Age = as.numeric(Sys.Date() - Create.Date)) %>%
arrange(Owner, Age) %>%
select(Opportunity.Title, Owner, Type, Value, Age, Client.Type, Contact.Attempts,
Pipeline, Stage, Source, Close.Date, Create.Date)
qualified = deals %>%
filter(Stage == 'Qualified') %>%
mutate(Create.Date = as.Date(Create.Date, format = '%Y-%m-%d')) %>%
mutate(Age = as.numeric(Sys.Date() - Create.Date)) %>%
arrange(Owner, Age) %>%
select(Opportunity.Title, Owner, Type, Value, Age, Client.Type, Contact.Attempts,
Pipeline, Stage, Source, Close.Date, Create.Date)
deals = deals %>%
filter(Stage != 'Weekly Forecast' & Stage != 'Qualified')
opportunities = rbind(leads, deals) %>%
mutate(Age = as.numeric(Sys.Date() - Create.Date)) %>%
arrange(Owner, Age) %>%
select(Opportunity.Title, Owner, Type, Value, Age, Client.Type, Contact.Attempts,
Pipeline, Stage, Source, Close.Date, Create.Date)
opportunities = rbind(weekly_forecast, qualified, opportunities) %>%
select(-Create.Date)
opportunities_h = opportunities %>%
filter(grepl('Angela', Owner) | grepl('Sabrina', Owner))
opportunities_t = setdiff(opportunities, opportunities_h) %>%
filter(Type == 'Deal') %>%
select(-Type, -Client.Type)
write.csv(file = '~/Desktop/opportunities_daily_h.csv', opportunities_h,
row.names = FALSE)
library(dplyr)
library(lubridate)
is_non_empty <- function(x) {
!is.na(x) & x != "" & !is.null(x)
}
# Read people.csv for Lead.Score data
people <- read.csv('~/Desktop/people.csv')
names(people) = str_replace(names(people), '^Person...', '')
people <- people %>%
rename(Contact.ID = ID) %>%
mutate(Contact.Attempts = Done.activities + Email.messages.count) %>%
select(Contact.ID, Contact.Attempts)
leads <- read.csv('~/Desktop/leads.csv')
names(leads) = str_replace(names(leads), '^Lead...', '')
leads <- leads %>%
select(-Source) %>%
rename(Created = Lead.created, Next.Activity = Next.activity,
Contact = Contact.person, Contact.ID = Contact.person.ID,
Archive.Status = Archive.status, Source = Source.channel) %>%
select(ID, Owner, Created, Next.Activity, Contact, Contact.ID, Source,
Labels, Archive.Status) %>%
# Join with people to get Lead.Score
left_join(people, by = "Contact.ID") %>%
filter(
# New filter: created in past 31 days OR Lead.Score > 10
(Created > (today() - days(31))),
!grepl('Testy', Contact, ignore.case = TRUE),
!grepl('Testive', Labels),
Archive.Status != 'Archived'
) %>%
mutate(
Created.POSIX = unclass(as.POSIXct(Created, format = '%Y-%m-%d %H:%M:%S'))
)
activities <- read.csv('~/Desktop/activities.csv')
names(activities) = str_replace(names(activities), '^Activity...', '')
activities <- activities %>%
rename(
Done.Time = Marked.as.done.time,
Contact.ID = Contact.person.ID,
User = Assigned.to.user,
Due = Due.date,
) %>%
select(Subject, Type, Done, Done.Time, Contact.ID, User, Lead.ID, Due) %>%
filter(Lead.ID %in% leads$ID)
combined <- left_join(leads, activities, by = c("ID" = "Lead.ID")) %>%
mutate(
Done.Time = if_else(!is_non_empty(Done.Time), '1970-01-01 00:00:00',
Done.Time),
Done.Time.POSIX = unclass(as.POSIXct(Done.Time, format = '%Y-%m-%d %H:%M:%S')),
TTC = as.integer((Done.Time.POSIX - Created.POSIX) / 3600),
TTC = if_else(TTC < 0, NA, TTC)
)
# attempts <- combined %>%
#  group_by(ID) %>%
#  filter(is_non_empty(Type)) %>%
# summarise(Attempts = n(), .groups = 'drop')
# first_contact <- combined %>%
#   group_by(ID) %>%
#   summarise(TTC = min(TTC, na.rm = TRUE), .groups = 'drop')
first_activity <- combined %>%
select(ID, Owner, Contact, Type, Due, Done.Time.POSIX) %>%
group_by(ID) %>%
slice_min(Due, n = 1, with_ties = FALSE) %>%
ungroup() %>%
filter(is_non_empty(Type)) %>%
rename(First.Activity = Type) %>%
select(ID, First.Activity)
output <- combined %>%
group_by(ID, Owner, Contact, Contact.Attempts) %>%
reframe(
Created = min(Created),
Next.Activity = if(all(is.na(Next.Activity))) NA else min(Next.Activity,
na.rm = TRUE),
Source = Source,
Labels = Labels,
.groups = 'drop'
) %>%
#  left_join(first_contact, by = "ID") %>%
left_join(first_activity, by = "ID") %>%
mutate(Contact.Attempts = replace_na(Contact.Attempts, 0)) %>%
select(Owner, Contact, Created, First.Activity,
Contact.Attempts, Next.Activity,
Source) %>%
distinct(.) %>%
arrange(Created)
output_h = output %>%
filter(grepl('Angela', Owner) | grepl('Sabrina', Owner))
write.csv(file = '~/Desktop/lead_tracking_h.csv', output_h, row.names = FALSE)
