# Enhanced function to parse various time formats to seconds
parse_time_to_seconds <- function(time_str) {
if (is.na(time_str) || is.null(time_str) || time_str == "" || time_str == "0") {
return(0)
}
time_str <- as.character(time_str)
total_seconds <- 0
# Extract hours (1h, 2h, etc.)
if (grepl("\\d+h", time_str)) {
hours <- as.numeric(gsub(".*?(\\d+)h.*", "\\1", time_str))
total_seconds <- total_seconds + (hours * 3600)
}
# Extract minutes (2m, 40m, etc.)
if (grepl("\\d+m", time_str)) {
minutes <- as.numeric(gsub(".*?(\\d+)m.*", "\\1", time_str))
total_seconds <- total_seconds + (minutes * 60)
}
# Extract seconds (33s, 7s, etc.)
if (grepl("\\d+s", time_str)) {
seconds <- as.numeric(gsub(".*?(\\d+)s.*", "\\1", time_str))
total_seconds <- total_seconds + seconds
}
# If it's just a number (no units), treat as seconds
if (grepl("^\\d+$", time_str)) {
total_seconds <- as.numeric(time_str)
}
return(total_seconds)
}
# Function to convert seconds back to readable format
seconds_to_readable <- function(seconds) {
if (seconds == 0) return("0s")
hours <- floor(seconds / 3600)
minutes <- floor((seconds %% 3600) / 60)
secs <- seconds %% 60
result <- ""
if (hours > 0) result <- paste0(result, hours, "h ")
if (minutes > 0) result <- paste0(result, minutes, "m ")
if (secs > 0) result <- paste0(result, secs, "s")
return(trimws(result))
}
# Test the function with your examples
test_values <- c("7s", "2m 40s", "1h 33m 33s", "0", "45s", "5m")
print("Testing time parsing:")
for (val in test_values) {
seconds <- parse_time_to_seconds(val)
readable <- seconds_to_readable(seconds)
print(paste(val, "->", seconds, "seconds ->", readable))
}
# Calculate Average Call Duration correctly
total_calls_row <- 1
total_talk_time_row <- 4
# Calculate for each person
angela_total_calls <- parse_time_to_seconds(everybody$Angela[total_calls_row])
angela_talk_time <- parse_time_to_seconds(everybody$Angela[total_talk_time_row])
angela_avg_seconds <- if(angela_total_calls > 0) angela_talk_time / angela_total_calls else 0
# Create the Average Call Duration row with readable format
avg_duration_row <- data.frame(
V1 = "Average Call Duration",
Angela = seconds_to_readable(round(angela_avg_seconds))
)
# Make sure column names match
names(avg_duration_row) <- names(everybody)
# Add the new row to everybody
everybody <- rbind(everybody, avg_duration_row) %>%
rename(' ' = a)
nextiva_h = everybody %>%
select(" ", Angela)
write.csv(file = '~/Desktop/nextiva_daily_h.csv', nextiva_h, row.names = FALSE)
